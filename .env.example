# Device configuration
DEVICE=cuda
# DEVICE=cpu

# Model IDs
TEXT2IMG_MODEL_ID=runwayml/stable-diffusion-v1-5
IMG2IMG_MODEL_ID=runwayml/stable-diffusion-v1-5
INPAINT_MODEL_ID=runwayml/stable-diffusion-inpainting
CONTROLNET_MODEL_ID=lllyasviel/control_canny-fp16

# Output directories
OUTPUT_DIR=outputs
TEXT2IMG_OUTPUT_DIR=outputs/text2img
IMG2IMG_OUTPUT_DIR=outputs/img2img
INPAINT_OUTPUT_DIR=outputs/inpaint
CONTROLNET_OUTPUT_DIR=outputs/controlnet

# Default generation parameters
DEFAULT_GUIDANCE_SCALE=7.5
DEFAULT_INFERENCE_STEPS=50
DEFAULT_NUM_IMAGES=1
DEFAULT_IMAGE_HEIGHT=768
DEFAULT_IMAGE_WIDTH=768

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/generation.log
